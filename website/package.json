{
  "name": "@batijs/elements",
  "version": "0.0.82",
  "description": "BatiJS website as Web Components",
  "type": "module",
  "main": "dist/elements/full.js",
  "scripts": {
    "dev": "vike dev",
    "dev:widget": "vite dev --mode widget",
    "build:pages": "vike build",
    "build:widget": "vite build --mode widget",
    "preview:widget": "http-server .",
    "check-types": "tsc --noEmit",
    "test": "tsc --noEmit",
    "release-widget": "bumpp --no-tag && bun run build:widget && bun run ../scripts/publish-widget.ts",
    "release-widget:ci": "bumpp --no-tag -y && bun run build:widget && bun run ../scripts/publish-widget.ts --provenance",
    "deploy": "vike build && wrangler deploy"
  },
  "keywords": [
    "bati",
    "batijs",
    "vike"
  ],
  "author": "Joël Charles <joel.charles91@gmail.com>",
  "repository": "https://github.com/vikejs/bati",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@batijs/features": "workspace:*",
    "@floating-ui/dom": "^1.7.6",
    "@floating-ui/utils": "^0.2.11",
    "@solid-primitives/scheduled": "^1.5.3",
    "@stackblitz/sdk": "^1.11.0",
    "@tailwindcss/vite": "^4.3.1",
    "babel-preset-solid": "^1.9.12",
    "bumpp": "^11.1.0",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.23",
    "esbuild": "^0.28.1",
    "http-server": "^14.1.1",
    "solid-element": "^1.9.1",
    "solid-js": "^1.9.13",
    "solid-motionone": "^1.0.4",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vike": "0.4.259",
    "vike-solid": "^0.8.2",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12"
  },
  "files": [
    "dist/elements"
  ]
}
