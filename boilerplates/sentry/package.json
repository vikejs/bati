{
  "name": "@batijs/sentry",
  "private": true,
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "bati-compile-boilerplate"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@batijs/compile": "workspace:*",
    "@sentry/vite-plugin": "^5.1.1",
    "@types/node": "^20.19.37",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@batijs/core": "workspace:*"
  },
  "files": [
    "dist/"
  ],
  "exports": {
    "./_.env": {
      "types": "./dist/_.env.d.mts"
    },
    "./_README.md": {
      "types": "./dist/_README.md.d.mts"
    },
    "./_TODO.md": {
      "types": "./dist/_TODO.md.d.mts"
    },
    "./_package.json": {
      "types": "./dist/_package.json.d.mts"
    },
    "./_vite.config.ts": {
      "types": "./dist/_vite.config.ts.d.mts"
    },
    "./pages/__client.ts": {
      "types": "./dist/pages/__client.ts.d.mts"
    }
  },
  "typesVersions": {
    "*": {
      "_.env": [
        "./dist/_.env.d.mts"
      ],
      "_README.md": [
        "./dist/_README.md.d.mts"
      ],
      "_TODO.md": [
        "./dist/_TODO.md.d.mts"
      ],
      "_package.json": [
        "./dist/_package.json.d.mts"
      ],
      "_vite.config.ts": [
        "./dist/_vite.config.ts.d.mts"
      ],
      "pages/__client.ts": [
        "./dist/pages/__client.ts.d.mts"
      ]
    }
  }
}
